{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python3 build_static.py --refresh",
  "outputDirectory": "static",
  "headers": [
    {
      "source": "/data/dashboard.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
